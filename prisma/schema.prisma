generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String
  dept      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RetrofitProject {
  id               String            @id @default(cuid())
  projectNo        String            @unique
  wbsNo            String
  name             String
  type             String
  priority         String            @default("normal")
  owner            String
  workshop         String            @default("")
  requestedAt      DateTime          @default(now())
  promisedAt       String?
  status           String            @default("preparing")
  progress         Int               @default(0)
  readiness        Int               @default(0)
  risk             String            @default("正常")
  vehiclesCount    Int               @default(1)
  sourceSystem     String            @default("TOCC")
  sourceVersion    String?
  vehicles         Vehicle[]
  tasks            RetrofitTask[]
  solutionVersions SolutionVersion[]
  qualityIssues    QualityIssue[]
  processRoutes    ProcessRoute[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Vehicle {
  id            String           @id @default(cuid())
  vehicleUid    String           @unique
  vin           String?
  prototypeNo   String?
  toccVehicleId String?
  model         String
  configuration String?
  source        String
  status        String
  location      String?
  stage         String           @default("")
  progress      Int              @default(0)
  projectId     String?
  project       RetrofitProject? @relation(fields: [projectId], references: [id])
  tasks         RetrofitTask[]
  traceEvents   PartTraceEvent[]
  qualityIssues QualityIssue[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model RetrofitTask {
  id              String          @id @default(cuid())
  taskNo          String          @unique
  projectId       String
  project         RetrofitProject @relation(fields: [projectId], references: [id])
  vehicleId       String
  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id])
  taskType        String
  stage           String
  status          String
  workshop        String?
  team            String?
  workstation     String?
  liftCode        String?
  plannedStart    DateTime?
  plannedEnd      DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  solutionVersion String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model SolutionVersion {
  id           String          @id @default(cuid())
  projectId    String
  project      RetrofitProject @relation(fields: [projectId], references: [id])
  version      String
  status       String
  author       String
  reviewRate   Int             @default(0)
  openComments Int             @default(0)
  frozenAt     DateTime?
  createdAt    DateTime        @default(now())

  @@unique([projectId, version])
}

model ProcessRoute {
  id         String          @id @default(cuid())
  routeNo    String          @unique
  projectId  String
  project    RetrofitProject @relation(fields: [projectId], references: [id])
  stage      String
  name       String
  version    String
  status     String          @default("draft")
  author     String
  operations Operation[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model Operation {
  id              String          @id @default(cuid())
  opNo            String          @unique
  routeId         String
  route           ProcessRoute    @relation(fields: [routeId], references: [id])
  seq             Int
  name            String
  workCenter      String
  standardMinutes Int             @default(0)
  isKey           Boolean         @default(false)
  status          String          @default("pending")
  assignee        String?
  startedAt       DateTime?
  finishedAt      DateTime?
  instructions    WorkInstruction[]
  reports         WorkReport[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model WorkReport {
  id          String    @id @default(cuid())
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id])
  opNo        String
  routeNo     String
  vehicleId   String
  operator    String
  measured    String?
  result      String    @default("passed")
  note        String?
  reportedAt  DateTime  @default(now())
}

model InspectionTemplate {
  id         String           @id @default(cuid())
  templateNo String           @unique
  name       String
  opNo       String?
  status     String           @default("released")
  author     String
  items      InspectionItem[]
  records    InspectionRecord[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model InspectionItem {
  id         String             @id @default(cuid())
  templateId String
  template   InspectionTemplate @relation(fields: [templateId], references: [id])
  seq        Int
  checkPoint String
  method     String?
  spec       String?
  createdAt  DateTime           @default(now())
}

model InspectionRecord {
  id         String                 @id @default(cuid())
  templateId String
  template   InspectionTemplate     @relation(fields: [templateId], references: [id])
  templateNo String
  vehicleId  String
  inspector  String
  result     String                 @default("passed")
  inspectedAt DateTime              @default(now())
  items      InspectionRecordItem[]
}

model InspectionRecordItem {
  id         String           @id @default(cuid())
  recordId   String
  record     InspectionRecord @relation(fields: [recordId], references: [id])
  seq        Int
  checkPoint String
  spec       String?
  measured   String?
  judged     String           @default("passed")
}

model WorkInstruction {
  id          String   @id @default(cuid())
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id])
  seq         Int
  step        String
  torqueSpec  String?
  tooling     String?
  qualityReq  String?
  createdAt   DateTime @default(now())
}

model MaterialRequirement {
  id           String   @id @default(cuid())
  taskNo       String
  vehicleUid   String?
  materialCode String
  materialName String
  materialType String
  requiredQty  Int
  readyQty     Int
  readiness    Int      @default(0)
  eta          String?
  sourceSystem String?
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PartTraceEvent {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  partCode    String
  serialNo    String?
  containerNo String?
  action      String
  disposition String?
  operator    String
  occurredAt  DateTime @default(now())
}

model QualityIssue {
  id         String           @id @default(cuid())
  issueNo    String           @unique
  projectId  String
  project    RetrofitProject  @relation(fields: [projectId], references: [id])
  vehicleId  String?
  vehicle    Vehicle?         @relation(fields: [vehicleId], references: [id])
  category   String
  title      String
  severity   String
  status     String
  owner      String
  dueAt      String?
  rootCause  String?
  action     String?
  horizontal Boolean          @default(false)
  sourceIssueNo String?
  verifiedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model IntegrationLog {
  id           String   @id @default(cuid())
  system       String
  interfaceKey String
  direction    String
  businessKey  String?
  status       String
  message      String?
  retryCount   Int      @default(0)
  occurredAt   DateTime @default(now())
}

model ScheduleSlot {
  id        String   @id @default(cuid())
  workshop  String
  resource  String
  am        String   @default("空闲")
  pm        String   @default("空闲")
  ev        String   @default("空闲")
  status    String   @default("healthy")
  updatedAt DateTime @updatedAt
}

model ScheduleAdjustment {
  id        String   @id @default(cuid())
  workshop  String
  resource  String
  shift     String
  before    String
  after     String
  operator  String
  reason    String
  createdAt DateTime @default(now())
}

model Gate {
  id     String  @id @default(cuid())
  key    String  @unique
  name   String
  detail String
  passed Boolean @default(false)
}

model ReviewPage {
  id       String @id @default(cuid())
  page     Int    @unique
  title    String
  owner    String
  status   String
  comments Int    @default(0)
}

model IntegrationSystem {
  id       String @id @default(cuid())
  name     String @unique
  purpose  String
  status   String
  latency  String
  success  String
  lastSync String
}

model VehicleTimelineEvent {
  id     String @id @default(cuid())
  time   String
  title  String
  detail String
  color  String
  sort   Int    @default(0)
}

model WorkshopState {
  id               String  @id @default("singleton")
  activeVersion    String  @default("V3.0")
  versionFrozen    Boolean @default(false)
  workshopPaused   Boolean @default(false)
  checkpointsDone  Int     @default(9)
  checkpointsTotal Int     @default(12)
  scanCount        Int     @default(4)
}

model WorkLog {
  id     String @id @default(cuid())
  time   String
  title  String
  detail String
  sort   Int    @default(0)
}
